  "options": {
    "step": {
      "init": {
        "title": "PetSnowy options",
        "description": "Calibration and external sensor integration for the litterbox meta sensors.",
        "data": {
          "weight_offset": "Weight offset",
          "external_motion_sensor": "External motion sensor",
          "pir_grace_minutes": "PIR grace window"
        },
        "data_description": {
          "weight_offset": "Grams added to the device's reported cat weight. Drives the 'Calibrated weight' sensor. Leave at 0 to match the raw reading.",
          "external_motion_sensor": "Optional motion/PIR binary sensor placed inside the litterbox. When set, every PIR-validated meta sensor (Last use (actual), Use rate (actual), etc.) only counts device events that coincide with a confirmed cat-inside window.",
          "pir_grace_minutes": "How long after the PIR last turned off a device event can still count as PIR-confirmed. Raise this if your device reports excretions several minutes after the cat leaves; lower it if false positives leak through. 0 disables the grace window (PIR must be currently on)."
        }
      }
    },
    "abort": {
      "not_supported": "Options are only available for the Snow+ Litterbox."
    }
  },
